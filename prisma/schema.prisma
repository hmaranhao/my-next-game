generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector(schema: "public")]
}

enum ProfileSource {
  STEAM
  MANUAL
}

model UserProfileSnapshot {
  id        String        @id @default(cuid())
  steamId   String?
  source    ProfileSource
  profile   Json
  createdAt DateTime      @default(now())

  consents               LgpdConsent[]
  recommendationSessions RecommendationSession[]

  @@index([steamId])
  @@map("user_profile_snapshots")
}

model LgpdConsent {
  id                  String   @id @default(cuid())
  profileSnapshotId   String?
  policyVersion       String
  consentedAt         DateTime @default(now())
  locale              String?
  userAgentHash       String?

  profileSnapshot UserProfileSnapshot? @relation(fields: [profileSnapshotId], references: [id], onDelete: SetNull)

  @@index([profileSnapshotId])
  @@map("lgpd_consents")
}

model RecommendationSession {
  id                String   @id @default(cuid())
  profileSnapshotId String
  createdAt         DateTime @default(now())

  profileSnapshot UserProfileSnapshot       @relation(fields: [profileSnapshotId], references: [id], onDelete: Cascade)
  candidates      RecommendationCandidate[]

  @@index([profileSnapshotId])
  @@map("recommendation_sessions")
}

model RecommendationCandidate {
  id             String                       @id @default(cuid())
  sessionId      String
  gameExternalId String
  gameMetadata   Json
  embedding      Unsupported("vector(128)")?
  distance       Float?
  rank           Int?
  createdAt      DateTime                     @default(now())

  session RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([gameExternalId])
  @@map("recommendation_candidates")
}

/** Vocab + norms used when indexing game vectors (must match query encoding). */
model EmbeddingCatalog {
  id          String   @id @default(cuid())
  label       String
  contextMeta Json
  gameCount   Int      @default(0)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  entries GameCatalogEntry[]

  @@index([isActive])
  @@map("embedding_catalogs")
}

/** Indexed game catalog for pgvector KNN search. */
model GameCatalogEntry {
  id               String                       @id @default(cuid())
  catalogId        String
  gameExternalId   String
  gameMetadata     Json
  searchEmbedding  Unsupported("vector(128)")
  popularityScore  Float                        @default(0)
  createdAt        DateTime                     @default(now())

  catalog EmbeddingCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, gameExternalId])
  @@index([catalogId])
  @@map("game_catalog_entries")
}
