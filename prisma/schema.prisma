generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector(schema: "public")]
}

enum ProfileSource {
  STEAM
  MANUAL
}

model UserProfileSnapshot {
  id        String        @id @default(cuid())
  steamId   String?
  source    ProfileSource
  profile   Json
  createdAt DateTime      @default(now())

  consents               LgpdConsent[]
  recommendationSessions RecommendationSession[]

  @@index([steamId])
  @@map("user_profile_snapshots")
}

model LgpdConsent {
  id                  String   @id @default(cuid())
  profileSnapshotId   String?
  policyVersion       String
  consentedAt         DateTime @default(now())
  locale              String?
  userAgentHash       String?

  profileSnapshot UserProfileSnapshot? @relation(fields: [profileSnapshotId], references: [id], onDelete: SetNull)

  @@index([profileSnapshotId])
  @@map("lgpd_consents")
}

model RecommendationSession {
  id                String   @id @default(cuid())
  profileSnapshotId String
  createdAt         DateTime @default(now())

  profileSnapshot UserProfileSnapshot       @relation(fields: [profileSnapshotId], references: [id], onDelete: Cascade)
  candidates      RecommendationCandidate[]

  @@index([profileSnapshotId])
  @@map("recommendation_sessions")
}

model RecommendationCandidate {
  id             String                       @id @default(cuid())
  sessionId      String
  gameExternalId String
  gameMetadata   Json
  embedding      Unsupported("vector(128)")?
  distance       Float?
  rank           Int?
  createdAt      DateTime                     @default(now())

  session RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([gameExternalId])
  @@map("recommendation_candidates")
}
