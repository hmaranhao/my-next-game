# Steam Web API — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# PostgreSQL + pgvector (docker-compose na raiz do projeto, próximo work item)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/my_next_game

# Neon (produção) — usado por scripts/reset-neon-db.mjs e deploy-production.mjs
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Kaggle (Steam Games Dataset — frankongames/steam-games-dataset)
# Coloque kaggle.json em ~/.kaggle/ ou use variáveis:
KAGGLE_USERNAME=
KAGGLE_KEY=

# Busca vetorial: cosine | l2
VECTOR_DISTANCE=cosine

# Quantos jogos indexar após ranking vetorial (default 1000)
VECTOR_TOP_K=1000

# Escolha final + TF.js só entre os N melhores candidatos (default 10)
VECTOR_FINAL_PICK_TOP_N=30
POPULARITY_BLEND=0.10
OVERLAP_BLEND=0.26
QUALITY_BLEND=0.12
LAST_PLAYED_BLEND=0.30
CO_OCCURRENCE_BLEND=0.20
TIER_BLEND=0.10
STUDIO_BLEND=0.08

# Catálogo curado (~128 jogos mainstream): npm run data:curated
# Reindex local após mudar regras: npm run db:reindex-curated
# INDEX_SOURCE=curated

# Busca de candidatos: auto (pg se indexado) | pg | memory
VECTOR_SEARCH_BACKEND=auto

# Indexação pgvector: omita para indexar todos os jogos em games.normalized.json (~122k)
# INDEX_GAME_LIMIT=5000
USE_SAMPLE_GAME_DATA=
