# Steam Web API — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# PostgreSQL + pgvector (docker-compose na raiz do projeto, próximo work item)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/my_next_game

# Kaggle (Steam Games Dataset — frankongames/steam-games-dataset)
# Coloque kaggle.json em ~/.kaggle/ ou use variáveis:
KAGGLE_USERNAME=
KAGGLE_KEY=

# Busca vetorial: cosine | l2
VECTOR_DISTANCE=cosine

# Quantos jogos indexar após ranking vetorial (default 1000)
VECTOR_TOP_K=1000

# Escolha final + TF.js só entre os N melhores candidatos (default 10)
VECTOR_FINAL_PICK_TOP_N=10

# Cloudflare Workers: true = amostra (data/samples). false = disco local ou R2 (GAME_DATA).
USE_SAMPLE_GAME_DATA=
