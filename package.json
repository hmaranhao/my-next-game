{
  "name": "my-next-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:index-embeddings": "tsx scripts/index-game-embeddings.ts",
    "db:prune-catalogs": "tsx scripts/prune-embedding-catalogs.ts",
    "db:index-embeddings:full": "tsx scripts/index-game-embeddings.ts",
    "db:studio": "prisma studio",
    "data:download": "PATH=\"$HOME/.local/bin:$PATH\" python3 scripts/download-kaggle-data.py",
    "data:setup": "pip install -r scripts/requirements-data.txt",
    "test:embedding": "node scripts/test-embedding.mjs",
    "test:ml": "node scripts/test-ml-features.mjs",
    "test:social-proof": "node scripts/test-social-proof.mjs",
    "test:game-tier": "node scripts/test-game-tier.mjs",
    "test:last-played": "node scripts/test-last-played-anchor.mjs",
    "test:playtime": "node scripts/test-playtime-weights.mjs",
    "data:curated": "node scripts/build-curated-catalog.mjs",
    "data:cloud": "npm run data:curated && node scripts/build-cloud-game-data.mjs",
    "test:10h-anchors": "node scripts/test-10h-anchors.mjs",
    "setup:cloud-db": "bash scripts/setup-cloud-db.sh",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@tensorflow/tfjs-vis": "^1.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "pg": "^8.21.0",
    "pg-cloudflare": "^1.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "wrangler": "^4.97.0"
  }
}
